## App
APP_NAME="SkillBridge Attendance API"
ENVIRONMENT="local"

## Database
# For local dev you can keep SQLite:
DATABASE_URL="sqlite:///./skillbridge.db"
# For Postgres (Neon / Railway), use something like:
# DATABASE_URL="postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME"

## JWT (standard tokens)
JWT_SECRET="change-me-please"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_HOURS=24

## Monitoring Officer extra layer
MONITORING_API_KEY="monitoring-key-change-me"
MONITORING_JWT_SECRET="change-me-monitoring"
MONITORING_JWT_EXPIRES_HOURS=1
